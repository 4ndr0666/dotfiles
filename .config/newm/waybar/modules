	// waybar-temperature
    "temperature": {
        "thermal-zone": 2,
        "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 70,
        "format-critical": "{icon}",
        "format": "{icon}",
        "format-icons": ["´ïï", "´ïè", "´ïë", "´ïê", "´ïç"],
    },
    "temperature#2": {
