        "format-stopped": "´èı",
        "state-icons": {
            "paused": "´àä",
            "playing": "´èï"
        },
		// Commands to execute on events
        "on-click": "mpc toggle",
    },
    "mpd#4": {
        "format": "´Ğ¼",
        "format-disconnected": "´Ğ¼",
        "format-paused": "´Ğ¼",
        "format-stopped": "´Ğ¼",
