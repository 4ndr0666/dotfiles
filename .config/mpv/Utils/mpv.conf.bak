--loop=inf
--speed=0.50
#--loop-playlist=yes
#setpts=PTS*2


########
#-SVP-#
#######
[svp]
--input-ipc-server=/tmp/mpvsocket
--hr-seek-framedrop=no
opengl-early-flush=yes
vf=format=fmt=yuv420p
hwdec=auto-copy
hwdec-codecs=all
--no-resume-playback
--ignore-path-in-watch-later-config=yes

###############
#-pseudo GUI-#
#############
#--player-operation-mode=pseudo-gui



#####################
#-Window Placement-#
###################
geometry=50%:50%
fs=no
force-window=immediate
#autofit-larger=90%x90%
#--geometry=50%+10+10/2
#--geometry=100%:100%
#--keep-open=always
#--keep-open-pause=no
#--taskbar-progress
#--no-border
#--osd-level=1
#--osd-bar=no
#window-scale=0.4
#save-position-on-quit=yes
#--video-rotate=<0-359|no>
#--video-sync=desync
#video-sync=display-resample
#keepaspect=no
#keep-open=yes
force-window=immediate
#osc=no
#ontop=yes

###################
#-video settings-#
################
--vd-lavc-dr=no
--no-resume-playback
--hr-seek-framedrop=no
--x11-bypass-compositor=no
--ignore-path-in-watch-later-config=yes


##########
#-Audio-#
########
audio-device=auto
#alsa/sysdefault:CARD=PCH
#audio-pitch-correction=no
#audio-channels=5.1
#audio-channels=auto
#volume-max=250


#-Disabled-#
###########
--sub-visibility=no
--no-audio

#######################
#-Act as Web Browser-#
#####################
# Pretend to be a web browser. Might fix playback with some streaming sites,
# but also will break with shoutcast streams.
#user-agent="Mozilla/5.0"

###################
#-cache settings-#
#################
#cache=yes
#demuxer-max-bytes=123400KiB
#cache-pause=no
#demuxer-readahead-secs=20

#############
#-Profiles-#
###########
#--gpu-context=wayland
#profile=gpu-hq
vo=gpu
#--gpu-context=wayland
#profile=gpu-hq
#vo=xv
#gpu-context=wayland
#--gpu-dumb-mode=yes
#--vo=gpu
#--vo=gl
#--vo=vdpau
#--vo=xv
#--vo=vaapi

#[vdpau]
#--hqscaling=9
#--denoise=1
#--scale=ewa_lanczossharp
#--scale=bilinear
#--cscale=bilinear
#--cscale=spline36
#--dither-depth=auto
#--fps=60
#--no-correct-pts
#--deband
#--deinterlace=yes
#--interpolation=yes
#--interpolation-preserve
#--tscale-param1=mitchell
#--tscale-param2=oversample
#--sws-scaler=lanczos
#--sws-fast=no
#--sws-allow-zimg=yes
#--zimg-fast=no
#--tone-mapping-max-boost=2.0
#sharpen=5
--input-ipc-server=/tmp/mpvsocket
--hwdec=auto-copy

[pyradio]
volume=50
#######################
#-Screenshot upgrade-#
#####################
screenshot-webp-lossless=yes
screenshot-directory=~/Pictures/Screens
screenshot-format=webp
screenshot-template="%F - [%P]v%#01n"
#############
#Extensions#
###########
image-display-duration=inf

[extension.gif]
loop-file=inf

[extension.webm]
loop-file=inf

[extension.jpg]
pause

[extension.png]
pause
